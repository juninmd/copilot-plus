{
  "name": "copilot-plus",
  "displayName": "Copilot+",
  "description": "Real-time GitHub Copilot quota display, session cost tracking, and agent scope explorer",
  "version": "0.1.11",
  "publisher": "juninmd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juninmd/copilot-plus"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["copilot", "quota", "requests", "agents", "github"],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilotPlus.turbo",
        "title": "Enable Turbo Mode",
        "category": "Copilot+",
        "icon": "$(zap)"
      },
      {
        "command": "copilotPlus.refresh",
        "title": "Refresh Quota",
        "category": "Copilot+",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotPlus.openAgentExplorer",
        "title": "Open Agent Explorer",
        "category": "Copilot+",
        "icon": "$(extensions)"
      },
      {
        "command": "copilotPlus.diagnose",
        "title": "Diagnose Quota Connection",
        "category": "Copilot+",
        "icon": "$(bug)"
      },
      {
        "command": "copilotPlus.showHistory",
        "title": "Show Usage History",
        "category": "Copilot+",
        "icon": "$(history)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotPlus",
          "title": "Copilot+",
          "icon": "resources/activitybar.svg"
        }
      ]
    },
    "views": {
      "copilotPlus": [
        {
          "id": "copilotPlus.agents",
          "name": "Agent Explorer"
        },
        {
          "id": "copilotPlus.models",
          "name": "Available Models"
        },
        {
          "id": "copilotPlus.tools",
          "name": "Available Tools"
        },
        {
          "id": "copilotPlus.mcps",
          "name": "MCP Servers"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "copilotPlus.turbo",
          "when": "view == copilotPlus.agents || view == copilotPlus.models || view == copilotPlus.tools || view == copilotPlus.mcps",
          "group": "navigation"
        },
        {
          "command": "copilotPlus.refresh",
          "when": "view == copilotPlus.agents || view == copilotPlus.models || view == copilotPlus.tools || view == copilotPlus.mcps",
          "group": "navigation"
        },
        {
          "command": "copilotPlus.diagnose",
          "when": "view == copilotPlus.agents",
          "group": "navigation"
        },
        {
          "command": "copilotPlus.showHistory",
          "when": "view == copilotPlus.agents || view == copilotPlus.models || view == copilotPlus.tools || view == copilotPlus.mcps",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Copilot+",
      "properties": {
        "copilotPlus.quotaTotal": {
          "type": "number",
          "default": 300,
          "description": "Your total monthly premium request quota (default 300 for Individual plan)"
        },
        "copilotPlus.refreshIntervalMinutes": {
          "type": "number",
          "default": 15,
          "minimum": 1,
          "maximum": 60,
          "description": "How often to refresh quota from GitHub (minutes)"
        },
        "copilotPlus.autoTurbo": {
          "type": "boolean",
          "default": false,
          "description": "Automatically enable experimental Copilot features on startup"
        }
      }
    }
  },
  "scripts": {
    "compile": "pnpm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "pnpm run check-types && node esbuild.js --production",
    "vscode:prepublish": "pnpm run package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
